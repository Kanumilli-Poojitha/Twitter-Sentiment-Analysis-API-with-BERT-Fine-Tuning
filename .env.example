# General
LOG_LEVEL=INFO
RANDOM_SEED=42

# Data and model
MODEL_NAME=distilbert-base-uncased
TEXT_COLUMN=text
LABEL_COLUMN=label
MAX_LENGTH=256

# Data paths
TRAIN_CSV_PATH=data/processed/train.csv
TEST_CSV_PATH=data/processed/test.csv
TRAIN_SAMPLE_SIZE=10000
TEST_SAMPLE_SIZE=2000

# Training output
MODEL_OUTPUT_DIR=model_output
RESULTS_DIR=results
METRICS_PATH=results/metrics.json
RUN_SUMMARY_PATH=results/run_summary.json

# Training hyperparameters
NUM_EPOCHS=1
TRAIN_BATCH_SIZE=8
EVAL_BATCH_SIZE=8
LEARNING_RATE=0.00002
WEIGHT_DECAY=0.01
LOGGING_STEPS=50
SAVE_TOTAL_LIMIT=1

# Batch prediction
PREDICTION_INPUT_CSV=data/unseen/input.csv
PREDICTION_OUTPUT_CSV=results/predictions.csv
PREDICTION_TEXT_COLUMN=text
PREDICTION_BATCH_SIZE=32

# API
API_HOST=0.0.0.0
API_PORT=8000

# UI
UI_PORT=8501
API_BASE_URL=http://api:8000
REQUEST_TIMEOUT_SECONDS=15
